{
  "name": "giseledemenezes-blog",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "db:generate": "kysely-codegen --dialect postgres --out-file=./app/db/types.d.ts --camel-case",
    "db:migrate": "tsx --env-file=.env ./app/db/scripts/migrate.ts && pnpm run db:generate",
    "db:rollback": "tsx --env-file=.env ./app/db/scripts/rollback.ts && pnpm run db:generate",
    "db:migration": "tsx ./app/db/scripts/migration.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "check": "react-router typegen && vp check",
    "check:types": "react-router typegen && tsc --noEmit",
    "check:lint": "vp lint"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/merriweather": "^5.2.11",
    "@neondatabase/serverless": "^1.1.0",
    "@react-router/node": "^7.13.1",
    "@react-router/serve": "^7.13.1",
    "@remix-run/form-data-parser": "^0.16.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@vercel/functions": "^3.4.3",
    "@vercel/og": "^0.11.1",
    "coerce-form-data": "^2.1.0",
    "composable-functions": "^5.0.0",
    "isbot": "^5.1.36",
    "kysely": "^0.28.14",
    "kysely-neon": "^2.0.2",
    "make-service": "^4.1.1",
    "make-typed-env": "^0.0.4",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-router": "^7.13.1",
    "react-router-typed-session": "^0.0.1",
    "resend": "^6.9.4",
    "sanitize-html": "^2.17.2",
    "schema-info": "^0.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@react-router/dev": "^7.13.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@types/sharp": "^0.32.0",
    "@types/turndown": "^5.0.6",
    "jsdom": "^29.0.1",
    "knip": "^6.0.1",
    "kysely-codegen": "^0.20.0",
    "lodash-es": "^4.17.23",
    "marked": "^17.0.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "turndown": "^7.2.2",
    "typescript": "~5.9.3",
    "vite": "^6.3.5",
    "vite-plus": "^0.1.13",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.32.1"
}
